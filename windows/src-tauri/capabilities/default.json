{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Core permissions for all ScanToExternApp windows: events, command invocation, and show/hide/focus of the tray-driven windows.",
  "windows": ["main", "preview", "settings", "history"],
  "permissions": [
    "core:default",
    "core:event:default",
    "core:window:allow-show",
    "core:window:allow-hide",
    "core:window:allow-set-focus",
    "core:window:allow-close",
    "core:window:allow-start-dragging"
  ]
}
